    {
      "Id": "SQL",
      "Type": "Compiled:String?",
      "ValueUsage": "RuntimeRead",
      "Value": "MERGE UserManagement.RolePage AS Target\r\nUSING\r\n(\r\n    SELECT\r\n        PageId\r\n    FROM OPENJSON(@{StringifyBody}, '$.Pages')\r\n    WITH\r\n    (\r\n        PageId INTEGER '$.Id'\r\n    )\r\n) AS Source\r\nON\r\n    Target.RoleId = @{$.Parameters.Id}\r\nAND\r\n    Target.PageId = Source.PageId\r\nWHEN NOT MATCHED BY TARGET THEN\r\n    INSERT\r\n    (\r\n        RoleId,\r\n        PageId,\r\n        LastChangedUser\r\n    )\r\n    VALUES\r\n    (\r\n        @{$.Parameters.Id},\r\n        Source.PageId,\r\n        @{$.Parameters.LastChangedUser}\r\n    )\r\nWHEN NOT MATCHED BY SOURCE\r\nAND\r\n    Target.RoleId = @{$.Parameters.Id}\r\nTHEN\r\n    DELETE;"
    },
    {
      "Id": "Timeout",
      "Type": "Compiled:Int32",
      "ValueUsage": "DesignTime",
      "Value": 60
    },
    {
      "Id": "Transaction",
      "Type": "Compiled:Twenty57.Linx.Plugins.Database.Shared.Transaction, Twenty57.Linx.Plugins.Database.Shared?",
